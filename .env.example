# === Required for production ===

# Resend API key (gratis tier 3000 mails/mnd) - https://resend.com
RESEND_API_KEY=

# Twilio voor WhatsApp (https://twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WhatsApp sender (sandbox default, of jouw goedgekeurde Twilio nummer)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# === Optional ===

# Google PageSpeed Insights API key (gratis aan te vragen)
PAGESPEED_API_KEY=

# Database / screenshot paths (default OK voor Docker)
# DB_PATH=/data/leads.db
# SCREENSHOT_DIR=/data/screenshots

PORT=3000
